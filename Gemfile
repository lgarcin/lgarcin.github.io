source "https://rubygems.org"

# Jekyll core
gem "jekyll", "~> 4.4"

# Plugins Jekyll
gem "jekyll-paginate"
gem "jekyll-seo-tag"
gem "jekyll-remote-theme"
gem "jekyll-compose"
gem "jekyll-sitemap"

# Outils de vérification (optionnel mais utile)
gem "html-proofer"

# Ruby standard lib fallback (Windows / compat)
gem "webrick"

# Timezone data (Windows only)
gem "tzinfo-data", platforms: :windows

# File watcher Windows (utile pour jekyll serve)
gem "wdm", platforms: :windows